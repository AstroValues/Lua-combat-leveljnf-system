local Combat = {}

function Combat.calculateDamage(attacker, defender)
local base    = attacker.attack
local reduced = math.max(1, base - math.floor(defender.defense * 0.5))
local variance = Utils.randomFloat(0.85, 1.15)
local damage  = Utils.round(reduced * variance)

```
local isCrit  = math.random() < attacker.critChance
local isDodge = math.random() < defender.dodgeChance

if isDodge then
    return 0, false, true
end
if isCrit then
    damage = Utils.round(damage * Config.CRIT_MULTIPLIER)
end
return math.max(1, damage), isCrit, false
```

end

function Combat.attack(attacker, defender)
local damage, isCrit, isDodge = Combat.calculateDamage(attacker, defender)
local log = “”

```
if isDodge then
    log = string.format("  %s dodges %s's attack!", defender.name, attacker.name)
else
    defender.hp = math.max(0, defender.hp - damage)
    attacker.damageDealt = attacker.damageDealt + damage
    defender.damageTaken = defender.damageTaken + damage

    if isCrit then
        log = string.format("  ★ CRITICAL! %s hits %s for %d damage! (HP: %d/%d)",
            attacker.name, defender.name, damage, defender.hp, defender.maxHp)
    else
        log = string.format("  %s hits %s for %d damage. (HP: %d/%d)",
            attacker.name, defender.name, damage, defender.hp, defender.maxHp)
    end
end

return damage, log
```

end

function Combat.duel(playerA, playerB, maxRounds)
maxRounds = maxRounds or 30
local log  = {}
local round = 0

```
playerA:fullHeal()
playerB:fullHeal()

table.insert(log, string.rep("═", 45))
table.insert(log, string.format("  DUEL: %s  vs  %s", playerA.name, playerB.name))
table.insert(log, string.format("  %s HP: %d  |  %s HP: %d", playerA.name, playerA.maxHp, playerB.name, playerB.maxHp))
table.insert(log, string.rep("═", 45))

while playerA:isAlive() and playerB:isAlive() and round < maxRounds do
    round = round + 1
    table.insert(log, string.format("\n  [ Round %d ]", round))

    -- Tick status effects
    for _, msg in ipairs(playerA:tickStatusEffects()) do table.insert(log, msg) end
    for _, msg in ipairs(playerB:tickStatusEffects()) do table.insert(log, msg) end

    if not playerA:isAlive() or not playerB:isAlive() then break end

    -- Player A attacks B
    local _, atkLog = Combat.attack(playerA, playerB)
    table.insert(log, atkLog)

    if not playerB:isAlive() then break end

    -- Player B attacks A
    local _, defLog = Combat.attack(playerB, playerA)
    table.insert(log, defLog)
end

-- Determine winner
local winner, loser
if playerA:isAlive() and not playerB:isAlive() then
    winner, loser = playerA, playerB
elseif playerB:isAlive() and not playerA:isAlive() then
    winner, loser = playerB, playerA
else
    -- Draw — higher HP percentage wins
    local aRatio = playerA.hp / playerA.maxHp
    local bRatio = playerB.hp / playerB.maxHp
    if aRatio >= bRatio then
        winner, loser = playerA, playerB
    else
        winner, loser = playerB, playerA
    end
    table.insert(log, "\n  Max rounds reached — closest HP wins!")
end

-- Update stats
winner.kills  = winner.kills  + 1
winner.wins   = winner.wins   + 1
loser.deaths  = loser.deaths  + 1
loser.losses  = loser.losses  + 1

local xpGain = Config.XP_KILL_BASE + Config.XP_WIN_BONUS +
               (loser.level * 10)
local leveled, newLevel = winner:addXp(xpGain)
loser:addXp(Utils.round(xpGain * 0.3))

-- Score update
winner.score = winner.score + (xpGain * 2)

table.insert(log, "\n" .. string.rep("═", 45))
table.insert(log, string.format("  🏆 WINNER: %s!", winner.name))
table.insert(log, string.format("  +%s XP awarded!", Utils.formatNumber(xpGain)))
if leveled then
    table.insert(log, string.format("  ⬆  LEVEL UP! %s is now level %d!", winner.name, newLevel))
end
table.insert(log, string.rep("═", 45))

return winner, loser, table.concat(log, "\n")
```

end

– ============================================================
– LEADERBOARD SYSTEM
– ============================================================

local Leaderboard = {}
Leaderboard.__index = Leaderboard

function Leaderboard.new()
local self = setmetatable({}, Leaderboard)
self.players = {}
return self
end

function Leaderboard:register(player)
self.players[player.name] = player
end

function Leaderboard:remove(name)
self.players[name] = nil
end

function Leaderboard:getSorted(key, limit)
key   = key   or “score”
limit = limit or Config.LEADERBOARD_SIZE

```
local list = {}
for _, p in pairs(self.players) do
    table.insert(list, p)
end

table.sort(list, function(a, b)
    return (a[key] or 0) > (b[key] or 0)
end)

local trimmed = {}
for i = 1, math.min(limit, #list) do
    trimmed[i] = list[i]
end
return trimmed
```

end

function Leaderboard:display(key, limit)
key   = key   or “score”
limit = limit or Config.LEADERBOARD_SIZE
local sorted = self:getSorted(key, limit)

```
local medals = { "🥇", "🥈", "🥉" }
local lines  = {
    string.rep("═", 60),
    string.format("  🏆  LEADERBOARD  —  Sorted by: %s  (Top %d)", key:upper(), limit),
    string.rep("═", 60),
    string.format("  %-4s %-16s %-8s %-8s %-10s %-6s", "Rank", "Name", "Level", "Class", key:upper(), "K/D"),
    string.rep("─", 60),
}

for i, p in ipairs(sorted) do
    local rank   = medals[i] or string.format("  #%d", i)
    local val    = Utils.formatNumber(p[key] or 0)
    local kd     = p:getKdRatio()
    table.insert(lines, string.format("  %-4s %-16s %-8d %-10s %-10s %-6s",
        rank, p.name, p.level, p.class, val, kd))
end

table.insert(lines, string.rep("═", 60))
return table.concat(lines, "\n")
```

end

function Leaderboard:getPlayerRank(name, key)
key = key or “score”
local sorted = self:getSorted(key, Utils.tableLength(self.players))
for i, p in ipairs(sorted) do
if p.name == name then return i end
end
return nil
end

