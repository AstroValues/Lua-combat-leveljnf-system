– ============================================================
– CONFIGURATION
– ============================================================

local Config = {
MAX_LEVEL        = 50,
BASE_XP          = 100,       – XP needed for level 2
XP_SCALE         = 1.5,       – XP multiplier per level
BASE_HP          = 100,
HP_PER_LEVEL     = 20,
BASE_ATK         = 15,
ATK_PER_LEVEL    = 3,
BASE_DEF         = 5,
DEF_PER_LEVEL    = 2,
CRIT_CHANCE      = 0.15,      – 15% base crit chance
CRIT_MULTIPLIER  = 2.0,
DODGE_CHANCE     = 0.08,      – 8% base dodge chance
XP_KILL_BASE     = 50,
XP_WIN_BONUS     = 25,
LEADERBOARD_SIZE = 10,
}

– ============================================================
– UTILITY FUNCTIONS
– ============================================================

local Utils = {}

function Utils.round(n)
return math.floor(n + 0.5)
end

function Utils.clamp(val, min, max)
if val < min then return min end
if val > max then return max end
return val
end

function Utils.randomFloat(min, max)
return min + math.random() * (max - min)
end

function Utils.formatNumber(n)
local s = tostring(math.floor(n))
local result = “”
local count = 0
for i = #s, 1, -1 do
count = count + 1
result = s:sub(i, i) .. result
if count % 3 == 0 and i ~= 1 then
result = “,” .. result
end
end
return result
end

function Utils.tableLength(t)
local count = 0
for _ in pairs(t) do count = count + 1 end
return count
end

function Utils.deepCopy(orig)
local copy = {}
for k, v in pairs(orig) do
if type(v) == “table” then
copy[k] = Utils.deepCopy(v)
else
copy[k] = v
end
end
return copy
end

– ============================================================
– XP / LEVELING SYSTEM
– ============================================================

local LevelSystem = {}

function LevelSystem.xpForLevel(level)
if level <= 1 then return 0 end
return Utils.round(Config.BASE_XP * (Config.XP_SCALE ^ (level - 2)))
end

function LevelSystem.totalXpForLevel(level)
local total = 0
for i = 2, level do
total = total + LevelSystem.xpForLevel(i)
end
return total
end

function LevelSystem.levelFromXp(xp)
local level = 1
while level < Config.MAX_LEVEL do
local needed = LevelSystem.totalXpForLevel(level + 1)
if xp >= needed then
level = level + 1
else
break
end
end
return level
end

function LevelSystem.xpToNextLevel(xp)
local level = LevelSystem.levelFromXp(xp)
if level >= Config.MAX_LEVEL then return 0 end
local needed = LevelSystem.totalXpForLevel(level + 1)
return needed - xp
end

– ============================================================
– PLAYER CLASS
– ============================================================

local Player = {}
Player.__index = Player

function Player.new(name, class)
local self = setmetatable({}, Player)
self.name       = name or “Unknown”
self.class      = class or “Warrior”
self.xp         = 0
self.level      = 1
self.kills      = 0
self.deaths     = 0
self.wins       = 0
self.losses     = 0
self.damageDealt = 0
self.damageTaken = 0
self.score      = 0
self.statusEffects = {}
self:recalculateStats()
self.hp         = self.maxHp
return self
end

function Player:recalculateStats()
self.level   = LevelSystem.levelFromXp(self.xp)
self.maxHp   = Config.BASE_HP  + (self.level - 1) * Config.HP_PER_LEVEL
self.attack  = Config.BASE_ATK + (self.level - 1) * Config.ATK_PER_LEVEL
self.defense = Config.BASE_DEF + (self.level - 1) * Config.DEF_PER_LEVEL

```
-- Class-based modifiers
if self.class == "Warrior" then
    self.maxHp   = Utils.round(self.maxHp * 1.2)
    self.defense = Utils.round(self.defense * 1.1)
elseif self.class == "Mage" then
    self.attack  = Utils.round(self.attack * 1.35)
    self.maxHp   = Utils.round(self.maxHp  * 0.85)
elseif self.class == "Rogue" then
    self.critChance = (Config.CRIT_CHANCE + 0.10)
    self.dodgeChance = (Config.DODGE_CHANCE + 0.10)
elseif self.class == "Paladin" then
    self.maxHp   = Utils.round(self.maxHp * 1.1)
    self.defense = Utils.round(self.defense * 1.2)
    self.attack  = Utils.round(self.attack * 0.9)
end

self.critChance  = self.critChance  or Config.CRIT_CHANCE
self.dodgeChance = self.dodgeChance or Config.DODGE_CHANCE
self.hp          = math.min(self.hp or self.maxHp, self.maxHp)
```

end

function Player:isAlive()
return self.hp > 0
end

function Player:heal(amount)
local prev = self.hp
self.hp = Utils.clamp(self.hp + amount, 0, self.maxHp)
return self.hp - prev
end

function Player:fullHeal()
self.hp = self.maxHp
end

function Player:addXp(amount)
local prevLevel = self.level
self.xp = self.xp + amount
self:recalculateStats()
if self.level > prevLevel then
return true, self.level  – leveled up
end
return false, self.level
end

function Player:applyStatusEffect(effect)
self.statusEffects[effect.name] = {
duration = effect.duration,
value    = effect.value,
type     = effect.type,
}
end

function Player:tickStatusEffects()
local messages = {}
for name, effect in pairs(self.statusEffects) do
if effect.type == “dot” then
self.hp = math.max(0, self.hp - effect.value)
table.insert(messages, self.name .. “ takes “ .. effect.value .. “ “ .. name .. “ damage!”)
elseif effect.type == “hot” then
local healed = self:heal(effect.value)
table.insert(messages, self.name .. “ regenerates “ .. healed .. “ HP from “ .. name .. “!”)
end
effect.duration = effect.duration - 1
if effect.duration <= 0 then
self.statusEffects[name] = nil
table.insert(messages, name .. “ fades from “ .. self.name .. “.”)
end
end
return messages
end

function Player:getKdRatio()
if self.deaths == 0 then
return self.kills > 0 and self.kills or 0
end
return string.format(”%.2f”, self.kills / self.deaths)
end

function Player:getSummary()
local lines = {
string.rep(“─”, 40),
string.format(”  %s  [%s]  Level %d”, self.name, self.class, self.level),
string.rep(“─”, 40),
string.format(”  HP:     %d / %d”, self.hp, self.maxHp),
string.format(”  ATK:    %d   DEF: %d”, self.attack, self.defense),
string.format(”  Crit:   %.0f%%  Dodge: %.0f%%”, self.critChance * 100, self.dodgeChance * 100),
string.format(”  XP:     %s  (Next: %s)”, Utils.formatNumber(self.xp), Utils.formatNumber(LevelSystem.xpToNextLevel(self.xp))),
string.format(”  Score:  %s”, Utils.formatNumber(self.score)),
string.format(”  K/D:    %s  (%d kills / %d deaths)”, self:getKdRatio(), self.kills, self.deaths),
string.format(”  Wins:   %d  Losses: %d”, self.wins, self.losses),
string.rep(“─”, 40),
}
return table.concat(lines, “\n”)
end

